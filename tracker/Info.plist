<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>NSHealthShareUsageDescription</key>
	<string>Metricly reads your health data to show steps, heart rate, sleep, and recovery insights alongside your workout tracking.</string>
	<key>NSHealthUpdateUsageDescription</key>
	<string>Metricly saves your workouts and body weight entries to Apple Health.</string>
	<key>NSMotionUsageDescription</key>
	<string>Metricly uses motion data to track distance and steps during indoor runs and walks.</string>
	<key>NSLocationWhenInUseUsageDescription</key>
	<string>Metricly uses your location to track your runs and walks — plotting your route on a map and calculating accurate distance and pace.</string>
	<key>UIBackgroundModes</key>
	<array>
		<string>location</string>
		<string>audio</string>
		<string>remote-notification</string>
	</array>
	<key>STRAVA_CLIENT_ID</key>
	<string>$(STRAVA_CLIENT_ID)</string>
	<key>STRAVA_CLIENT_SECRET</key>
	<string>$(STRAVA_CLIENT_SECRET)</string>
	<!-- Declares English as the development language. With this in place,
	     Xcode's "Export Localizations" picks up every String(localized:)
	     call in source as the English baseline, and adding a new language
	     becomes a strings-file drop instead of a code refactor. -->
	<key>CFBundleDevelopmentRegion</key>
	<string>en</string>
</dict>
</plist>
